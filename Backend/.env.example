# Server
PORT=5001
NODE_ENV=development

# MongoDB Atlas
# Get your connection string from MongoDB Atlas: Connect > Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/eventbooking?retryWrites=true&w=majority

# JWT - Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_key_min_64_characters
JWT_EXPIRES_IN=7d

# Bcrypt salt rounds (default: 10)
BCRYPT_SALT_ROUNDS=10

# Service fee as a decimal (default: 0.05 = 5%)
SERVICE_FEE_PERCENT=0.05

# Currency for payments (default: usd)
CURRENCY=usd

# CORS - comma-separated frontend URLs
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Email (optional - for booking confirmations)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM="Event Organizer <your_email@gmail.com>"

# Frontend URL for emails
FRONTEND_URL=http://localhost:3000
