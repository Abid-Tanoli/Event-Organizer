# API Base URL for backend
# Local development:
VITE_API_URL=http://localhost:5001/api

# Production (Vercel): set in Vercel dashboard
# VITE_API_URL=https://your-backend.vercel.app/api

# Service fee override (must match backend SERVICE_FEE_PERCENT)
# VITE_SERVICE_FEE_PERCENT=0.05

# Events per page override
# VITE_EVENTS_PER_PAGE=6
