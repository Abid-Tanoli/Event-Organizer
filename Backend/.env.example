# Server
PORT=5001
NODE_ENV=development

# MongoDB Atlas
# Get your connection string from MongoDB Atlas: Connect > Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/eventbooking?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d

# CORS - comma-separated frontend URLs
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Email (optional - for booking confirmations)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM="Event Organizer <your_email@gmail.com>"

# Frontend URL for emails
FRONTEND_URL=http://localhost:3000
